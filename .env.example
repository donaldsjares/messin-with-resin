# Copy these into your Vercel project's Environment Variables (Settings → Environment Variables).
# For local dev with `vercel dev`, copy this file to `.env.local` and fill it in.

# Owner login password (choose something strong).
ADMIN_PASSWORD=

# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Vercel KV / Upstash Redis (added automatically when you attach the
# Vercel KV / Upstash integration to the project). Required for saved product
# edits to persist in production.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob (added automatically when you create a Blob store in the
# project's Storage tab). Required for product photo uploads.
BLOB_READ_WRITE_TOKEN=
